    "orientation": "portrait",
    "themeColor": "#1e40af",
    "themeColorDark": "#172554",
    "navigationColor": "#1e40af",
    "navigationColorDark": "#172554",
    "backgroundColor": "#0f172a",
    "enableNotifications": false,
    "startUrl": "/espace-agent",
    "iconUrl": "https://VOTRE-DOMAINE-PROD/images/icons/icon-512.png",
